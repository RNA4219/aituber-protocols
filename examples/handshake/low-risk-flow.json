      "message": {
        "spec_version": "0.2-draft",
        "proof_id": "prf-20240315-g7h8i9j0k1l2",
        "challenge_id": "ch-20240315-a1b2c3d4e5f6",
        "agent_id": "agent-alice-main",
        "instance_id": "inst-alice-001",
        "nonce": "n0nc3_l0wr1sk_4l1c3_20240315t101500z",
        "timestamp": "2024-03-15T10:15:30Z",
        "expires_at": "2024-03-15T10:25:30Z",
        "intent": "basic_interaction",
        "capability_digest": "sha256:chat.basic:profile.read:status.share",
        "identity_version": 5,
        "revocation_epoch": 12,
        "policy_epoch": 3,
        "session_epoch": 1,
