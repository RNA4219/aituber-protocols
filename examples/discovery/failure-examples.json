    },
    {
      "scenario_id": "failure_008",
      "platform": "discord",
      "failure_type": "FIRST_SEEN_RESTRICTED",
      "description": "初回接触のAgentによるHigh-RISK操作が制限される",
      "steps": [
        {
          "step_number": 1,
          "phase": "bootstrap_trust_evaluation",
          "description": "First-seen判定",
          "request": {
            "agent_id": "agt_new_agent",
