{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/ledger/events/recovery-initiated.schema.json",
  "title": "Ledger Event Payload - recovery.initiated",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "recovery_id": {
      "$ref": "../core/common.schema.json#/$defs/idString"
    },
    "initiated_at": {
      "$ref": "../core/common.schema.json#/$defs/timestamp"
    },
    "recovery_reason": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2048
    },
    "initiated_by_key_id": {
      "$ref": "../core/common.schema.json#/$defs/idString"
    },
    "revocation_epoch": {
      "$ref": "../core/common.schema.json#/$defs/nonNegativeInteger"
    },
    "quarantine_required": {
      "type": "boolean"
    }
  },
  "required": [
    "recovery_id",
    "initiated_at",
    "recovery_reason",
    "initiated_by_key_id",
    "revocation_epoch",
    "quarantine_required"
  ]
}
