{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/exchange/profile-response.schema.json",
  "title": "Exchange Profile Response Message",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "protocol_version": {
      "type": "string",
      "minLength": 1
    },
    "message_id": {
      "type": "string",
      "minLength": 1
    },
    "message_type": {
      "type": "string",
      "const": "profile.response"
    },
    "timestamp": {
      "$ref": "../core/common.schema.json#/$defs/timestamp"
    },
    "agent_id": {
      "$ref": "../core/common.schema.json#/$defs/idString"
    },
    "instance_id": {
      "$ref": "../core/common.schema.json#/$defs/idString"
    },
    "session_id": {
      "$ref": "../core/common.schema.json#/$defs/idString"
    },
    "sequence": {
      "$ref": "../core/common.schema.json#/$defs/nonNegativeInteger"
    },
    "signature_or_mac": {
      "type": "string",
      "minLength": 16
    },
    "body": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "profile": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "display_name": {
              "type": "string",
              "minLength": 1
            },
            "summary": {
              "type": "string",
              "minLength": 1
            },
            "platform_bindings": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "platform_type": {
                    "type": "string",
                    "minLength": 1
                  },
                  "display_handle": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": [
                  "platform_type",
                  "display_handle"
                ]
              }
            }
          },
          "required": [
            "display_name",
            "summary"
          ]
        }
      },
      "required": [
        "profile"
      ]
    }
  },
  "required": [
    "protocol_version",
    "message_id",
    "message_type",
    "timestamp",
    "agent_id",
    "instance_id",
    "session_id",
    "sequence",
    "signature_or_mac",
    "body"
  ]
}
