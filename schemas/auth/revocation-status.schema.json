{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/auth/revocation-status.schema.json",
  "title": "Revocation Status",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "spec_version": {
      "type": "string",
      "minLength": 1
    },
    "agent_id": {
      "$ref": "../core/common.schema.json#/$defs/idString"
    },
    "controller_id": {
      "$ref": "../core/common.schema.json#/$defs/idString"
    },
    "agent_status": {
      "$ref": "../core/common.schema.json#/$defs/agentStatus"
    },
    "quarantine_status": {
      "$ref": "../core/common.schema.json#/$defs/quarantineLevel"
    },
    "revocation_epoch": {
      "$ref": "../core/common.schema.json#/$defs/nonNegativeInteger"
    },
    "policy_epoch": {
      "$ref": "../core/common.schema.json#/$defs/nonNegativeInteger"
    },
    "identity_version": {
      "$ref": "../core/common.schema.json#/$defs/nonNegativeInteger"
    },
    "ledger_checkpoint": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "checked_at": {
      "$ref": "../core/common.schema.json#/$defs/timestamp"
    },
    "fresh_until": {
      "$ref": "../core/common.schema.json#/$defs/timestamp"
    },
    "high_risk_eligible": {
      "type": "boolean"
    },
    "recovery_state": {
      "type": "string",
      "enum": ["none", "initiated", "in_progress", "completed"]
    },
    "compromise_state": {
      "type": "string",
      "enum": ["none", "suspected", "confirmed", "historical"]
    },
    "key_states": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "key_id": {
            "$ref": "../core/common.schema.json#/$defs/idString"
          },
          "scope": {
            "$ref": "../core/common.schema.json#/$defs/keyScope"
          },
          "status": {
            "type": "string",
            "enum": ["active", "revoked", "expired", "quarantined"]
          },
          "effective_at": {
            "$ref": "../core/common.schema.json#/$defs/timestamp"
          }
        },
        "required": ["key_id", "scope", "status", "effective_at"]
      }
    },
    "signatures": {
      "type": "array",
      "items": {
        "$ref": "../core/common.schema.json#/$defs/signature"
      },
      "minItems": 1
    }
  },
  "required": [
    "spec_version",
    "agent_id",
    "agent_status",
    "quarantine_status",
    "revocation_epoch",
    "policy_epoch",
    "identity_version",
    "ledger_checkpoint",
    "checked_at",
    "fresh_until",
    "high_risk_eligible",
    "signatures"
  ]
}
